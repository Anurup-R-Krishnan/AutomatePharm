# Selvam Medicals — Environment Configuration
# Copy this file to .env and fill in the actual values for your environment

# Application Configuration
APP_NAME=Selvam Medicals
DATABASE_URL=sqlite:///./selvam_medicals.db
# For PostgreSQL: postgresql://user:password@localhost:5432/selvam_medicals

# Security
SECRET_KEY=your-super-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# Twilio (SMS & Notifications)
TWILIO_SID=your_twilio_account_sid
TWILIO_TOKEN=your_twilio_auth_token
TWILIO_FROM=+1234567890

# SMTP (Email Notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password

# Shop Details (for invoices & reports)
SHOP_NAME=Selvam Medicals
SHOP_ADDRESS=123 Main Street, City, State 12345
SHOP_PHONE=+91-9876543210
GST_NUMBER=12ABCDE1234F1Z0
DRUG_LICENSE=DL-XXXX/YYYY

# Redis (for caching & Celery)
REDIS_URL=redis://localhost:6379

# AI/ML Configuration
FACE_RECOGNITION_MODEL=default
OCR_LANGUAGE=eng
STRIPE_DETECTION_CONFIDENCE=0.8

# Reporting
REPORTS_OUTPUT_PATH=./reports_output
MAX_PDF_SIZE_MB=100

# Environment
DEBUG=False
ENVIRONMENT=production
LOG_LEVEL=INFO
