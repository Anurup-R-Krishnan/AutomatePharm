# Twilio WhatsApp Credentials
# Get these from your Twilio Console (https://console.twilio.com)
TWILIO_ACCOUNT_SID=your_account_sid_here
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# Optional: custom SQLite path. If omitted, the app uses ./database.db.
# PHARMACY_DB_PATH=database.db

# Store identity used in SMS templates
PHARMACY_STORE_NAME=Selvam Medicals

# SMS provider settings
SMS_PROVIDER_MODE=auto
SMS_PROVIDER_URL=
SMS_PROVIDER_KEY=
SMS_PROVIDER_SENDER=Selvam Medicals
SMS_PROVIDER_TIMEOUT=15

# DB - Postgresql

DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/db

# ── Reorder / n8n WhatsApp Conversation Flow ──────────────────────────────

# Public base URL of this backend (used to build the n8n callback URL)
BASE_URL=https://your-backend.example.com

# Outbound n8n webhook — backend POSTs here to trigger the WhatsApp message
N8N_WEBHOOK_URL=https://your-n8n-instance.example.com/webhook/reorder-outbound

# Shared secret between n8n and this backend for the inbound callback
N8N_INBOUND_WEBHOOK_SECRET=change_me_to_a_strong_random_secret

# WhatsApp-enabled Twilio number (used in the outbound message payload)
PHARMACY_WHATSAPP_NUMBER=whatsapp:+919xxxxxxxxx
